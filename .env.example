# ==============================================================================
# TripMate Agent 환경변수 설정 템플릿
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. 프론트엔드 설정 (Next.js)
# ------------------------------------------------------------------------------
# VWorld 지도 API 서비스 키 (프론트엔드 브라우저에서 직접 로드)
NEXT_PUBLIC_VWORLD_SERVICE_KEY=C737D607-1011-3AD8-98A0-EE550472F20A_MOCK

# 프론트엔드가 백엔드 API와 통신하기 위한 베이스 URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000


# ------------------------------------------------------------------------------
# 2. 백엔드 및 ETL 공통 설정 (FastAPI / Python)
# ------------------------------------------------------------------------------
# 데이터베이스 접속 URL (SQLAlchemy 2.0 Async/Sync 드라이버 지정)
# SQLite3 로컬 파일을 사용합니다.
DATABASE_URL=sqlite:///./tripmate.db

# LLM: Gemini API 키 및 기본 모델 설정
GEMINI_API_KEY=AIzaSyYourGeminiApiKeyHere_MOCK
GEMINI_ENGINE_VERSION=gemini-2.0-flash

# YouTube API 키
# 할당량 초과 대비 및 최소 활용을 원칙으로 하며, 백업 스크래핑 라이브러리가 동작합니다.
YOUTUBE_API_KEY=AIzaSyYourYoutubeApiKeyHere_MOCK

# Geocoding REST API 키 (Kakao Local 또는 Naver Map API 중 선택)
# 아래 예제는 Kakao Local API 기준입니다.
GEOLOCATION_PROVIDER=kakao
GEOLOCATION_API_KEY=your_kakao_rest_api_key_here_MOCK
