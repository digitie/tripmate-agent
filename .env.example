# ==============================================================================
# TripMate Agent 환경변수 설정 템플릿
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. 프론트엔드 설정 (Next.js)
# ------------------------------------------------------------------------------
# VWorld 지도 API 서비스 키 (프론트엔드 브라우저에서 직접 로드)
NEXT_PUBLIC_VWORLD_SERVICE_KEY=your_vworld_browser_key_here

# 프론트엔드가 백엔드 API와 통신하기 위한 베이스 URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:9041
CORS_ALLOW_ORIGINS=http://localhost:9042,http://127.0.0.1:9042,http://localhost:3000,http://127.0.0.1:3000,http://localhost:13000,http://127.0.0.1:13000,http://localhost:13100,http://127.0.0.1:13100

# ------------------------------------------------------------------------------
# 2. 백엔드 및 ETL 공통 설정 (FastAPI / Python)
# ------------------------------------------------------------------------------
# 데이터베이스 접속 URL
# SQLite + SpatiaLite를 `aiosqlite` 비동기 드라이버로 사용합니다.
DATABASE_URL=sqlite+aiosqlite:///./tripmate.db
SPATIALITE_EXTENSION_PATH=mod_spatialite
SQLITE_WAL_ENABLED=true

# LLM: Gemini API 키 및 기본 모델 설정
# 허용 모델 목록과 기본값의 코드 단일 출처는 backend/app/core/config.py의 GEMINI_ENGINE_OPTIONS입니다.
# 웹 설정 화면은 /api/settings의 gemini_engine_options 응답을 그대로 사용합니다.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_ENGINE_VERSION=gemini-2.0-flash

# YouTube API 키
# 소형 프로젝트 기준 공식 YouTube Data API v3를 기본 수집 경로로 사용합니다.
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_USE_OFFICIAL_API=true
YOUTUBE_SEARCH_DAILY_BUDGET_UNITS=1000
YOUTUBE_MAX_VIDEOS_PER_RUN=20

# 자막 폴백 순서
TRANSCRIPT_PROVIDER_ORDER=youtube-transcript-api,yt-dlp,faster-whisper

# FFmpeg 실행 파일 경로
# Windows live는 scripts\ensure-windows-ffmpeg.ps1이 .local\ffmpeg 아래에 내려받아 .env에 기록한 경로를 사용합니다.
# ffprobe는 Windows live 사전 검증에서만 사용하며, 애플리케이션 runtime에는 주입하지 않습니다.
# Docker Compose 컨테이너 경로를 바꿀 때는 DOCKER_FFMPEG_PATH를 사용합니다.
FFMPEG_PATH=ffmpeg
DOCKER_FFMPEG_PATH=/usr/bin/ffmpeg

# RustFS 미디어 저장소
# RustFS는 별도 로컬 Docker 서비스로 구동하고, 원본 동영상/자막/전사 결과/대표 프레임은 무기한 보존합니다.
RUSTFS_ENABLED=true
RUSTFS_ENDPOINT=http://127.0.0.1:9003
RUSTFS_PUBLIC_BASE_URL=http://127.0.0.1:9003/krtour-map
RUSTFS_DOCKER_ENDPOINT=http://rustfs:9000
RUSTFS_CONSOLE_URL=http://127.0.0.1:9004
RUSTFS_ACCESS_KEY=your_rustfs_access_key_here
RUSTFS_SECRET_KEY=your_rustfs_secret_key_here
RUSTFS_BUCKET_RAW_VIDEOS=krtour-map
RUSTFS_BUCKET_SUBTITLES=krtour-map
RUSTFS_BUCKET_FRAMES=krtour-map
RUSTFS_OBJECT_PREFIX=features
RUSTFS_REGION=us-east-1
RUSTFS_HEALTH_PATH=/health/live
MEDIA_RETENTION_POLICY=infinite

# Geocoding / Reverse Geocoding 공급자 설정
# VWorld를 최우선으로 사용하고, Kakao/Naver는 보조 검색·검증으로 사용합니다.
# kraddr-geo는 현재 연계하지 않습니다.
GEOLOCATION_PROVIDER=vworld
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here
VWORLD_SERVICE_KEY=your_vworld_server_key_here

# ------------------------------------------------------------------------------
# 3. MCP 서버 설정
# ------------------------------------------------------------------------------
# 쓰기 도구는 필요한 개발·운영 환경에서 명시적으로 켜고, 모든 변경은 감사 로그에 기록합니다.
MCP_WRITE_ENABLED=false
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8010
MCP_STREAMABLE_HTTP_PATH=/mcp

# ------------------------------------------------------------------------------
# 4. 스케줄러 및 동시성 설정
# ------------------------------------------------------------------------------
SCHEDULER_ENABLED=true
CRAWL_DEFAULT_INTERVAL_DAYS=7
CRAWL_MAX_CONCURRENT_VIDEOS=4
HTTP_MAX_CONCURRENT_REQUESTS=8
SCHEDULER_POLL_INTERVAL_SECONDS=5
SCHEDULER_HEARTBEAT_INTERVAL_SECONDS=30
SCHEDULER_STALE_THRESHOLD_SECONDS=300
SCHEDULER_MAX_RETRIES=3
